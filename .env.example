# Discord bot token
DISCORD_TOKEN=your_token_here

# Staff channel used for Plex down reports
STAFF_CHANNEL_ID=123456789012345678

# Role allowed to manage the Plex liveboard
STAFF_ROLE_ID=123456789012345678

# Optional user IDs to ping when someone reports a Plex server as down
STAFF_PING_USER_IDS=886584649013411880,1229271933736976395

# Storage
DB_PATH=./data/reports.sqlite3

# Optional Plex URL health checks (set all three together to enable polling)
PLEX_ALPHA_URL=
PLEX_OMEGA_URL=
PLEX_DELTA_URL=
PLEX_PROBE_TIMEOUT_SECONDS=15
PLEX_PROBE_INTERVAL_MINUTES=5
